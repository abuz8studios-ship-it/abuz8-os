{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ABUZ8 OS",
  "version": "1.0.0",
  "identifier": "ai.abuz8.os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8042"
  },
  "app": {
    "windows": [
      {
        "title": "ABUZ8 OS — Sovereign Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "center": true,
        "backgroundColor": "#03090d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Productivity",
    "shortDescription": "Sovereign agentic AI operating system",
    "longDescription": "ABUZ8 OS — 35 wired systems including multi-brain routing, 3D memory cortex, audit chain, creator studio, and a 98-item migration registry. Bismillah.",
    "copyright": "Copyright © 2026 ABUZ8 LLC",
    "publisher": "ABUZ8 LLC",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
